rules_version = '2';

// ============================================================
//  Regras de segurança — Espaço Provável (multi-cliente)
//
//  Só utilizadores AUTENTICADOS acedem a seja o que for.
//  Os 2 utilizadores (gestora e dono) têm acesso total a todas
//  as empresas. Sem login, ninguém vê nada — mesmo com o link.
//
//  Isolamento por empresa: tudo vive sob empresas/{empresaId}/...
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    // Empresas e TODAS as suas subcoleções (config, funcionarios,
    // faturas, recibos, proformas, calendario, documentos, faltas…)
    match /empresas/{empresaId} {
      allow read, write: if autenticado();

      match /{documento=**} {
        allow read, write: if autenticado();
      }
    }

    // Perfis dos utilizadores
    match /users/{userId} {
      allow read: if autenticado();
      // A criação/gestão dos 2 utilizadores faz-se na consola Firebase.
      allow write: if autenticado() && request.auth.uid == userId;
    }

    // Registo de acessos / auditoria (RGPD): criar sempre, nunca alterar/apagar
    match /audit_logs/{logId} {
      allow read: if autenticado();
      allow create: if autenticado();
      allow update, delete: if false;
    }
  }
}
